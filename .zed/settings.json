{
	"prettier": {
		"allowed": false
	},
	"formatter": {
		"language_server": {
			"name": "biome"
		}
	},
	"wrap_guides": [120],
	"lsp": {
		"vscode-css-language-server": {
			"settings": {
				"css": {
					"lint": {
						"unknownAtRules": "ignore"
					}
				}
			}
		},
		"vtsls": {
			"settings": {
				"typescript": {
					"preferences": {
						"importModuleSpecifier": "non-relative"
					}
				}
			}
		}
	}
}
