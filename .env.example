# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unlearn-rag-course

# AI Provider (ollama | groq | deepseek | lmstudio | unsloth)
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:14b

# Unsloth/OpenAI-compatible provider settings (only needed if AI_PROVIDER=unsloth)
# AI_PROVIDER_BASE_URL=http://localhost:8000
# AI_API_KEY=your_api_key_here

# Embedding Provider (voyage | ollama)
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-4-large

# Reranker Provider (voyage)
# VOYAGE_API_KEY is required for reranking even when EMBEDDING_PROVIDER=ollama
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2.5

# API Keys (only needed for cloud providers)
# VOYAGE_API_KEY=your_voyage_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
