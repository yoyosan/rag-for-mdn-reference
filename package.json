{
	"name": "unlearn-dev-rag-course",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"type-check": "tsc --noEmit",
		"check-all": "bun type-check && bun lint",
		"chunk-docs": "bun run scripts/chunk-docs.ts",
		"db:generate": "bun --env-file=.env.local drizzle-kit generate --config=drizzle.config.ts",
		"db:migrate": "bun --env-file=.env.local drizzle-kit migrate --config=drizzle.config.ts",
		"db:seed": "bun --env-file=.env.local scripts/seed-db.ts",
		"db:embeddings": "bun --env-file=.env.local scripts/generate-embeddings.ts",
		"semantic-search": "bun --env-file=.env.local scripts/semantic-search.ts",
		"rag-query": "bun --env-file=.env.local scripts/rag-query.ts"
	},
	"packageManager": "bun@1.3.13",
	"dependencies": {
		"@ai-sdk/groq": "3.0.38",
		"@ai-sdk/react": "3.0.179",
		"@langchain/textsplitters": "1.0.1",
		"@tailwindcss/typography": "0.5.19",
		"@types/slug": "5.0.9",
		"ai": "6.0.175",
		"clsx": "2.1.1",
		"drizzle-orm": "0.45.2",
		"gray-matter": "4.0.3",
		"langchain": "1.3.5",
		"lucide-react": "1.11.0",
		"next": "16.2.6",
		"pg": "8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "10.1.0",
		"react-syntax-highlighter": "16.1.1",
		"rehype-highlight": "7.0.2",
		"remark-gfm": "4.0.1",
		"slug": "11.0.1",
		"voyageai": "0.2.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@tailwindcss/postcss": "4.2.4",
		"@types/node": "20.19.39",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/react-syntax-highlighter": "15.5.13",
		"babel-plugin-react-compiler": "1.0.0",
		"bun-scan": "1.1.2",
		"drizzle-kit": "0.31.10",
		"tailwindcss": "4.2.4",
		"typescript": "5.9.3"
	},
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	],
	"overrides": {
		"langsmith": ">=0.6.0"
	}
}
